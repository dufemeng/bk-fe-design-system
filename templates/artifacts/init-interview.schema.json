{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bfds.local/schemas/init-interview.schema.json",
  "title": "BFDS Impeccable Init Interview Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "confirmedAt",
    "source",
    "productPath",
    "designPath",
    "productMode",
    "designMode",
    "questions",
    "userConfirmationQuote"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "confirmedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": ["user-interview", "existing-context-confirmed", "user-provided-context"]
    },
    "productPath": {
      "type": "string",
      "minLength": 1
    },
    "designPath": {
      "type": "string",
      "minLength": 1
    },
    "productMode": {
      "type": "string",
      "enum": ["created", "existing", "refreshed"]
    },
    "designMode": {
      "type": "string",
      "enum": ["scan", "seed", "existing", "refreshed"]
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "answerQuote"],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1
          },
          "answerQuote": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "userConfirmationQuote": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
