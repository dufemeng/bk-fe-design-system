{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bfds.local/schemas/brainstorm-dialogue.schema.json",
  "title": "BFDS Brainstorm Dialogue Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "createdAt",
    "surfaceEvidence",
    "mode",
    "turns",
    "approachesPresented",
    "userConfirmationQuote"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "surfaceEvidence": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["socratic", "user-skipped"]
    },
    "turns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "question", "answerQuote", "designImplication"],
        "properties": {
          "dimension": {
            "type": "string",
            "enum": [
              "primary-action",
              "user-mindset",
              "content-data-range",
              "state-edge-cases",
              "visual-direction",
              "scene-sentence",
              "anchor-reference",
              "scope-fidelity",
              "constraints-accessibility",
              "local-preservation"
            ]
          },
          "question": { "type": "string", "minLength": 1 },
          "answerQuote": { "type": "string", "minLength": 1 },
          "designImplication": { "type": "string", "minLength": 1 }
        }
      }
    },
    "approachesPresented": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "userConfirmationQuote": {
      "type": "string",
      "minLength": 1
    },
    "skipReasonQuote": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
