{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bfds.local/schemas/selection-evidence.schema.json",
  "title": "BFDS Selection Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "selectedAt",
    "selectionQuote",
    "selectedOption",
    "workbench",
    "options"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "selectedAt": {
      "type": "string",
      "format": "date-time"
    },
    "selectionQuote": {
      "type": "string",
      "minLength": 1
    },
    "selectedOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[ABC](?:\\+[ABC])*$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "mergedFrom": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["A", "B", "C"]
          },
          "uniqueItems": true
        },
        "decisionNotes": {
          "type": "string"
        }
      }
    },
    "workbench": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["A", "B", "C"],
      "properties": {
        "A": { "type": "string", "minLength": 1 },
        "B": { "type": "string", "minLength": 1 },
        "C": { "type": "string", "minLength": 1 }
      }
    }
  }
}
