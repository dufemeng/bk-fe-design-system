{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bfds.local/schemas/qa-plan.schema.json",
  "title": "BFDS QA Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "targetRoutes",
    "viewports",
    "states",
    "interactions",
    "referenceScreenshots",
    "checks",
    "blockers",
    "impeccable",
    "reports"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "targetRoutes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["route", "purpose"],
        "properties": {
          "route": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "authState": { "type": "string" },
          "dataState": { "type": "string" }
        }
      }
    },
    "viewports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "width", "height"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "width": { "type": "integer", "minimum": 320 },
          "height": { "type": "integer", "minimum": 320 }
        }
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "setup", "expected"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "setup": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "minLength": 1 },
          "blockingLevel": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] }
        }
      }
    },
    "interactions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "steps", "expected"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "expected": { "type": "string", "minLength": 1 },
          "blockingLevel": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] }
        }
      }
    },
    "referenceScreenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact", "description"],
        "properties": {
          "artifact": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "viewport": { "type": "string" },
          "state": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "category", "description", "blockingLevel"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": {
            "type": "string",
            "enum": ["contract", "font", "spacing", "color", "asset", "content", "icon", "state", "interaction", "responsive", "accessibility", "impeccable", "ai-shortcut"]
          },
          "description": { "type": "string", "minLength": 1 },
          "blockingLevel": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "impeccable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detect", "critique"],
      "properties": {
        "detect": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "targets"],
          "properties": {
            "enabled": { "type": "boolean" },
            "targets": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "notes": { "type": "string" }
          }
        },
        "critique": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "target": { "type": "string" },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "reports": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qaReport", "evidenceDir"],
      "properties": {
        "qaReport": { "type": "string", "minLength": 1 },
        "evidenceDir": { "type": "string", "minLength": 1 }
      }
    }
  }
}
