{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bfds.local/schemas/directions-evidence.schema.json",
  "title": "BFDS Directions Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "createdAt",
    "surfaceEvidence",
    "options",
    "selfCheck"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "surfaceEvidence": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["A", "B", "C"],
      "properties": {
        "A": { "$ref": "#/$defs/option" },
        "B": { "$ref": "#/$defs/option" },
        "C": { "$ref": "#/$defs/option" }
      }
    },
    "selfCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "usesTrustedContext",
        "noProductScopeAdded",
        "differencesAreSubstantial",
        "criticalStateOrInteractionCovered"
      ],
      "properties": {
        "usesTrustedContext": { "type": "boolean" },
        "noProductScopeAdded": { "type": "boolean" },
        "differencesAreSubstantial": { "type": "boolean" },
        "criticalStateOrInteractionCovered": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    }
  },
  "$defs": {
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "optionId",
        "name",
        "designThesis",
        "sourceConstraints",
        "hierarchy",
        "density",
        "motion",
        "stateTreatment",
        "layoutStrategy",
        "interactionModel",
        "visualSignature",
        "differenceDimensions",
        "keep",
        "change",
        "avoid",
        "risks",
        "bestFor"
      ],
      "properties": {
        "optionId": {
          "type": "string",
          "enum": ["A", "B", "C"]
        },
        "name": { "type": "string", "minLength": 1 },
        "designThesis": { "type": "string", "minLength": 1 },
        "sourceConstraints": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "hierarchy": { "type": "string", "minLength": 1 },
        "density": { "type": "string", "minLength": 1 },
        "motion": { "type": "string", "minLength": 1 },
        "stateTreatment": { "type": "string", "minLength": 1 },
        "layoutStrategy": { "type": "string", "minLength": 1 },
        "interactionModel": { "type": "string", "minLength": 1 },
        "visualSignature": { "type": "string", "minLength": 1 },
        "differenceDimensions": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "enum": ["information-architecture", "hierarchy", "density", "state-treatment", "interaction-model", "motion-role", "local-preservation", "visual-signature"]
          },
          "uniqueItems": true
        },
        "keep": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "change": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "avoid": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "bestFor": { "type": "string", "minLength": 1 }
      }
    }
  }
}
